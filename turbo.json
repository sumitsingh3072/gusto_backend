{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "dependsOn": ["prisma:generate"]
    },
    "test:e2e": {
      "dependsOn": ["build"]
    },
    "prisma:generate": {
      "cache": false
    },
    "prisma:migrate:dev": {
      "cache": false
    }
  }
}
