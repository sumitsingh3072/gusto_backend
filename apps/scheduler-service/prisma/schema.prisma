generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("SCHEDULER_DATABASE_URL")
  schemas  = ["scheduler"]
}

// Per-user trigger windows so cohorts are staggered rather than firing on one
// global clock tick, avoiding a thundering herd against Swiggy's MCP servers.
model ScheduleConfig {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  scoutTime     DateTime @map("scout_time")     // T-2h
  notifyTime    DateTime @map("notify_time")    // T-1h
  executeTime   DateTime @map("execute_time")   // T-30m
  timezone      String   @default("Asia/Kolkata")
  lastDispatchedDate DateTime? @map("last_dispatched_date") // scoutTime fired today
  lastNotifiedDate   DateTime? @map("last_notified_date")   // notifyTime fired today
  lastFinalizedDate  DateTime? @map("last_finalized_date")  // executeTime fired today
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("schedule_config")
  @@schema("scheduler")
}
