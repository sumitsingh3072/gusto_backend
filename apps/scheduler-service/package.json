{
  "name": "scheduler-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@gusto/config": "workspace:*",
    "@gusto/contracts": "workspace:*",
    "@gusto/logger": "workspace:*",
    "@gusto/swagger": "workspace:*",
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/swagger": "^11.4.6",
    "@prisma/client": "^5.18.0",
    "axios": "^1.7.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@gusto/tsconfig": "workspace:*",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "prisma": "^5.18.0",
    "ts-jest": "^29.2.5"
  }
}
