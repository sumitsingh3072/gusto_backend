generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("ORCHESTRATOR_DATABASE_URL")
  schemas  = ["orchestrator"]
}

// One row per user per calendar day, tracking where that day's meal is
// in the Scout -> Hacker -> Approval -> Sentinel lifecycle.
model WorkflowState {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  cycleDate     DateTime @map("cycle_date")
  phase         String   // SCOUTING | OPTIMIZING | AWAITING_APPROVAL | APPROVED | SKIPPED | EXECUTING | COMPLETE
  addressId     String?  @map("address_id")
  restaurantId  String?  @map("restaurant_id")
  shortlist     Json?    @map("shortlist")
  optimizedCart Json?    @map("optimized_cart")
  rejectedItemIds Json?  @map("rejected_item_ids")
  decision      String?  // APPROVE | SWAP | SKIP
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, cycleDate])
  @@map("workflow_state")
  @@schema("orchestrator")
}
