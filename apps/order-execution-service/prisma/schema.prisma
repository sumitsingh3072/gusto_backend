generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
  previewFeatures = ["multiSchema"]
  // "native" for local dev (Windows/macOS); "linux-musl-openssl-3.0.x" for
  // the Docker runtime (node:20-alpine ships OpenSSL 3, not the legacy
  // 1.1.x Prisma defaults to on musl without this override -- confirmed by
  // a real `docker build`+`docker run`, which failed with "Error loading
  // shared library libssl.so.1.1: No such file or directory" until this
  // was added).
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("ORDER_EXECUTION_DATABASE_URL")
  schemas  = ["order_execution"]
}

model Order {
  id               String    @id @default(uuid()) @map("order_id")
  userId           String    @map("user_id")
  swiggyOrderRef   String?   @unique @map("swiggy_order_ref") // null until place_food_order succeeds
  status           String    // PENDING_CONFIRMATION | PLACED | OUT_FOR_DELIVERY | DELIVERED | FAILED
  cart             Json
  savingsAchieved  Int       @map("savings_achieved") // paise, not Decimal -- see CLAUDE.md money rule
  agentLogs        String?   @map("agent_logs")
  placedAt         DateTime? @map("placed_at")
  deliveredAt      DateTime? @map("delivered_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("orders")
  @@schema("order_execution")
}
