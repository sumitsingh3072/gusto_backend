{
  "name": "auth-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@prisma/client": "^5.18.0",
    "@gusto/contracts": "workspace:*",
    "@gusto/event-bus": "workspace:*",
    "@gusto/config": "workspace:*",
    "@gusto/logger": "workspace:*",
    "@gusto/auth-middleware": "workspace:*",
    "axios": "^1.7.4",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.18.0",
    "@gusto/tsconfig": "workspace:*",
    "@types/jsonwebtoken": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.12"
  }
}
