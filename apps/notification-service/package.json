{
  "name": "notification-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@prisma/client": "^5.18.0",
    "@aws-sdk/client-sns": "^3.620.0",
    "@gusto/contracts": "workspace:*",
    "@gusto/event-bus": "workspace:*",
    "@gusto/config": "workspace:*",
    "@gusto/logger": "workspace:*"
  },
  "devDependencies": { "prisma": "^5.18.0" }
}
