# Copy to .env and fill in real values for local development.
# .env is gitignored -- this file is the checked-in reference for which
# variables exist and what they're for.

# ---- Shared ----
NODE_ENV=development
LOG_LEVEL=info

# ---- Per-service Postgres URLs (one RDS instance, one schema per service) ----
AUTH_DATABASE_URL=postgresql://gusto:password@localhost:5432/gusto?schema=auth
ORCHESTRATOR_DATABASE_URL=postgresql://gusto:password@localhost:5432/gusto?schema=orchestrator
ORDER_EXECUTION_DATABASE_URL=postgresql://gusto:password@localhost:5432/gusto?schema=order_execution
ESCROW_DATABASE_URL=postgresql://gusto:password@localhost:5432/gusto?schema=escrow
SCHEDULER_DATABASE_URL=postgresql://gusto:password@localhost:5432/gusto?schema=scheduler
NOTIFICATION_DATABASE_URL=postgresql://gusto:password@localhost:5432/gusto?schema=notification

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Event bus (SQS/EventBridge; localstack in dev) ----
EVENT_BUS_ENDPOINT=http://localhost:4566
EVENT_BUS_REGION=ap-south-1

# ---- Swiggy MCP tool servers (only mcp-gateway-service calls these) ----
SWIGGY_MCP_FOOD_URL=https://mcp.swiggy.com/food
SWIGGY_MCP_INSTAMART_URL=https://mcp.swiggy.com/instamart
SWIGGY_MCP_DINEOUT_URL=https://mcp.swiggy.com/dineout

# ---- Swiggy OAuth 2.1 + PKCE (auth-service only) ----
# Gusto brokers Swiggy for many end users, so this is Swiggy's *delegated
# auth* flow: client_id is issued to Gusto at onboarding (pre-registered,
# allowlisted), not obtained via runtime Dynamic Client Registration.
# https://mcp.swiggy.com/builders/docs/start/enterprise/delegated-auth/
SWIGGY_OAUTH_BASE_URL=https://mcp.swiggy.com
SWIGGY_OAUTH_CLIENT_ID=
# Must exactly match one of the redirect_uris Swiggy allowlisted for this
# client_id -- Swiggy rejects inexact string matches. Use an http://localhost
# URI for local dev.
SWIGGY_OAUTH_REDIRECT_URI=
SWIGGY_OAUTH_SCOPE=mcp:tools mcp:resources mcp:prompts
# Not used by the current delegated-auth PKCE flow (public client, no client
# secret) -- kept here in case Swiggy's onboarding process ever issues one.
SWIGGY_OAUTH_CLIENT_SECRET=

# ---- AI Agent Service ----
AI_AGENT_SERVICE_URL=http://localhost:8001
ANTHROPIC_API_KEY=

# ---- Gusto's own session JWT (auth-service only; separate from the Swiggy
# access token, which never leaves auth-service) ----
JWT_SECRET=
JWT_EXPIRES_IN_SECONDS=43200

# ---- AES-256-GCM key encrypting the Swiggy access token at rest.
# Base64-encoded 32 bytes, e.g.: openssl rand -base64 32
MCP_TOKEN_ENCRYPTION_KEY=
